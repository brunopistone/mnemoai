# AWS Bedrock Mantle: auth via a short-lived bearer token minted from your
# standard AWS (SigV4) credentials. Model IDs are bare provider names. Mantle
# serves models under different protocols, selected with API_PROTOCOL:
#   chat_completions (default) -> base /v1 (OpenAI Chat Completions); most models
#   responses                  -> base /openai/v1 (OpenAI Responses); e.g. openai.gpt-5.4
#   anthropic                  -> base /anthropic (Anthropic Messages); Claude models
# Works for both MODEL_ID (chat) and VISION_MODEL_ID (image description).
MODEL_ID:
  NAME: qwen.qwen3-32b # bare Mantle model id
  TYPE: mantle
  REGION: us-east-1
  MAX_TOKENS: 8192
  # Auth: by default a short-lived token is minted from AWS credentials. To use
  # a short-term Bedrock API key instead, uncomment API_KEY here (per-model) or
  # set BEDROCK_API_KEY in the ENV section at the bottom (applies to all calls).
  # API_KEY: bedrock-api-key-XXXXXXXX
# Responses-API model example (GPT-5.4 lives in us-west-2, not us-east-1):
# MODEL_ID:
#   NAME: openai.gpt-5.5
#   TYPE: mantle
#   REGION: us-west-2
#   API_PROTOCOL: responses
#   MAX_TOKENS: 128000
# Anthropic (Claude) model example:
# MODEL_ID:
#   NAME: anthropic.claude-opus-4-8
#   TYPE: mantle
#   REGION: us-east-1
#   API_PROTOCOL: anthropic
#   MAX_TOKENS: 128000
# MODEL_ID:
#   NAME: xai.grok-4.3
#   TYPE: mantle
#   REGION: us-west-2
#   API_PROTOCOL: responses
#   MAX_TOKENS: 30000
# Vision via Mantle (vision-capable models):
VISION_MODEL_ID:
  NAME: qwen.qwen3-vl-235b-a22b-instruct
  TYPE: mantle
  REGION: us-east-1
# VISION_MODEL_ID:
#   NAME: openai.gpt-5.5
#   TYPE: mantle
#   REGION: us-east-1
#   API_PROTOCOL: responses
# VISION_MODEL_ID:
#   NAME: anthropic.claude-opus-4-8
#   TYPE: mantle
#   REGION: us-east-1
#   API_PROTOCOL: anthropic
# VISION_MODEL_ID:
#   NAME: xai.grok-4.3
#   TYPE: mantle
#   REGION: us-west-2
#   API_PROTOCOL: responses
# Model parameters
#Anthropic max context window
MAX_CONVERSATION_TOKENS: 1000000
#GPT max context window
#MAX_CONVERSATION_TOKENS: 272000
DOC_MAX_TOKENS: 524288
# Ask for confirmation before every execute_bash shell command (Claude Code-style).
# Set to false to run shell commands without prompting (trusted/automation setups).
REQUIRE_BASH_CONFIRMATION: true
# Ask for confirmation before every fs_write / file_edit file modification.
# Set to false to write files without prompting (trusted/automation setups).
REQUIRE_WRITE_CONFIRMATION: true
# RAG Configuration
ENABLE_RAG: true
RAG:
  MAX_TOKENS: 8192
  EMBED_MODEL_ID:
    NAME: qwen3-embedding:0.6b
    TYPE: ollama
    HOST: localhost
    PORT: 11434
  CHUNK_TOKENS: 1024
  SEARCH:
    SEMANTIC_WEIGHT: 0.5 # Semantic similarity weight (0-1)
    KEYWORD_WEIGHT: 0.5 # BM25 keyword weight (0-1)
  VECTOR_STORE:
    TYPE: chromadb # or faiss
  EMBEDDINGS:
    FALLBACK_ENABLED: true
    FALLBACK_TYPE: "sha256" # or "random", "zeros"
    CACHE_ENABLED: true
    CACHE_SIZE: 1000 # LRU cache size for embeddings
# Episodic Memory Configuration (Enhanced)
ENABLE_EPISODIC_MEMORY: true
EPISODIC_MEMORY:
  ENABLED: true
  STORE_TYPE: chromadb # or faiss
  # Similarity Thresholds
  DUPLICATE_THRESHOLD: 0.95 # Higher = stricter duplicate detection
  RETRIEVAL_THRESHOLD: 0.7 # Higher = more strict retrieval
  # Hybrid Search Weights
  SEMANTIC_WEIGHT: 0.7 # Semantic similarity weight (0-1)
  KEYWORD_WEIGHT: 0.3 # Keyword matching weight (0-1)
  # Token and Size Limits
  MAX_TOKENS_PER_EPISODE: 400 # Max tokens for episode text
  MAX_EPISODES: 1000 # Maximum stored episodes
  MAX_AGE_DAYS: 90 # Maximum episode age
  # Success Detection (configurable markers)
  SUCCESS_MARKERS:
    - thanks
    - thank you
    - perfect
    - great
    - worked
    - good
    - excellent
    - awesome
  CORRECTION_MARKERS:
    - wrong
    - error
    - fix
    - actually
    - instead
    - incorrect
    - "no"
    - not right
  ERROR_PATTERNS:
    - "error:"
    - "failed:"
    - "exception:"
    - "could not"
    - "unable to"
    - "error occurred"
    - "failed to"
    - "an error"
    - "the error"
  # Storage Behavior
  IMMEDIATE_STORAGE: true # Store episodes immediately (not delayed)
  MIN_TOOLS_OR_LENGTH: 300 # Minimum response length if no tools used
  # Query Enhancement
  ENABLE_QUERY_EXPANSION: true # Expand queries with synonyms
  QUERY_EXPANSION_TERMS: 3 # Max terms to add per query
# ACE Playbook Configuration (Agentic Context Engineering)
ENABLE_PLAYBOOK: true
PLAYBOOK:
  MAX_ENTRIES: 500 # Maximum playbook entries before refinement
  SIMILARITY_THRESHOLD: 0.85 # Threshold for merging similar strategies
  MAX_INJECT: 10 # Maximum entries to inject per query

# Query Routing Configuration
# When enabled, queries are classified and routed to specialized tool subsets
# Categories: simple_qa (no tools), code, research, knowledge, full (all tools)
ENABLE_ROUTING: true
ROUTING_PROMPT: |
  <query_classifier>
  <role>
  The assistant is a query classifier. It reads a user message and outputs
  exactly one category name. It does not answer the user's question,
  provide explanations, or produce any text beyond the category name itself.
  </role>

  <categories>
  <category name="simple_qa">
  Conversational messages that can be answered from the model's internal
  knowledge without invoking any external tool. This includes greetings,
  factual explanations, conceptual questions, math, thank-you messages,
  and general chitchat.
  Examples: "What is Python?", "Hello", "Explain recursion to me",
  "Thanks, that worked", "What's the difference between a list and a tuple?"
  </category>

  <category name="code">
  Tasks that require interacting with the local file system, editing code,
  running shell commands, or performing git operations. The user is asking
  the assistant to read, create, modify, or search files, run tests,
  execute scripts, or manage version control.
  Examples: "Read main.py", "Fix the bug in auth.py", "Run the tests",
  "Create a new config file", "Show me the git log",
  "Search for all TODO comments in the project"
  </category>

  <category name="research">
  Tasks that require searching the web or fetching content from an external
  URL. The user wants information that is not in local files and is not
  general knowledge — it requires live lookup.
  Examples: "Search for the latest Python release",
  "What's the current price of Bitcoin?",
  "Read this URL: https://example.com/article",
  "Find recent news about LangGraph"
  </category>

  <category name="knowledge">
  Tasks that involve reading, indexing, or querying user-provided documents
  such as PDFs, CSVs, DOCX, or JSON files. This includes summarizing a
  document, searching within previously indexed documents, or extracting
  specific information from a file that is too long to read at once and
  needs to be indexed first.
  Examples: "Summarize this PDF", "Search in my documents for X",
  "What does the report say about Y?", "Index the CSV and find all rows
  where status is failed"
  </category>

  <category name="full">
  Tasks that clearly span multiple categories above, or tasks whose scope
  is ambiguous enough that restricting the tool set could prevent successful
  completion.
  Examples: "Read this PDF and write a summary to a file",
  "Search the web for best practices and update the README",
  "Analyze the CSV, compare with online benchmarks, and commit the results"
  </category>
  </categories>

  <decision_rules>
  The classifier follows these rules in order:

  1. If the message spans two or more categories (e.g., web search AND file
  writing), the classifier outputs "full".
  2. If the classifier is uncertain which single category applies, it outputs
  "full". Choosing "full" is always safe; choosing a narrow category
  incorrectly may prevent the assistant from completing the task.
  3. If conversation context is provided, the classifier uses it to
  disambiguate short follow-up messages. A follow-up like "yes, do it"
  inherits the category of the task being discussed.
  4. The classifier does not explain its reasoning. It outputs only the
  category name as a single word, with no punctuation, no quotes, and no
  additional text.
  </decision_rules>
  </query_classifier>

# Orchestrator Configuration
# When enabled (requires ENABLE_ROUTING), complex tasks classified as "full"
# are decomposed into subtasks executed by specialized workers
ENABLE_ORCHESTRATION: true
ORCHESTRATOR_PROMPT: |
  <task_orchestrator>
  <role>
  The assistant is a task decomposer. It receives a complex user request and
  breaks it into ordered subtasks. Each subtask is assigned to exactly one
  category that determines which tools will be available to execute it.
  </role>

  <categories>
  <category name="simple_qa">
  No tools needed. The worker answers from internal knowledge only.
  </category>
  <category name="code">
  File operations, code editing, shell commands, git operations,
  file search (glob/grep), todo management, plan mode, background tasks.
  </category>
  <category name="research">
  Web search and URL fetching. Use when the worker needs live information
  from the internet.
  </category>
  <category name="knowledge">
  Document reading (PDF, CSV, DOCX, JSON), RAG indexing and querying.
  Use when the worker needs to read or search within user-provided documents.
  </category>
  </categories>

  <output_format>
  Output a JSON array of subtasks. Each subtask has:
  - "description": A clear, self-contained instruction for the worker.
  The worker does not see the original user request — only this description
  and context from previously completed subtasks.
  - "category": One of: simple_qa, code, research, knowledge.

  Order subtasks so that dependencies come first. If subtask B needs results
  from subtask A, place A before B. Workers receive results from all
  previously completed subtasks as context.

  Output ONLY the JSON array. No markdown fences, no explanation, no other text.
  </output_format>

  <rules>
  1. Each subtask must be self-contained. A worker must understand what to do
  from the description alone, plus context from prior results.
  2. Minimize the number of subtasks. Do not split what can be done in one step.
  3. If the task can be handled by a single category, return a single-element array.
  4. Never create more than 5 subtasks.
  5. Do not create a subtask for "summarizing" or "aggregating" — that is handled
  automatically after all workers finish.
  </rules>
  </task_orchestrator>
AGGREGATOR_PROMPT: |
  <result_aggregator>
  <role>
  The assistant synthesizes results from multiple completed subtasks into a
  single coherent response for the user. It does not re-execute any tasks
  or call any tools.
  </role>

  <rules>
  1. Present the combined results naturally, as if a single assistant completed
  the entire request.
  2. Do not mention subtasks, workers, orchestration, or internal process details.
  3. If subtask results conflict, note the discrepancy.
  4. Be concise — do not repeat information that appears in multiple results.
  5. Use the same formatting conventions as the subtask results (markdown,
  code blocks, etc.).
  </rules>
  </result_aggregator>

# LLM Interaction Configuration (Enhanced)
LLM:
  # Thinking/Reasoning
  ENABLE_THINKING: true # Enable thinking tags (verbose mode)
  # Retry Logic
  RETRY_ENABLED: true
  MAX_RETRIES: 3
  RETRY_DELAY: 1.0 # Seconds between retries
  RETRY_BACKOFF: 2.0 # Exponential backoff multiplier
  # Token Counting (Model-specific)
  TOKEN_COUNTING:
    OLLAMA_APPROXIMATION: 1.3 # Multiplier for Ollama (chars to tokens)
    FALLBACK_MODEL: "gpt-4" # Tiktoken model for fallback
  # Context Management
  SUMMARIZATION_THINK: false
  # Compaction: when the conversation exceeds MAX_CONVERSATION_TOKENS it is
  # auto-compacted — older messages are summarized into the system prompt while
  # the most recent messages are kept verbatim.
  KEEP_RECENT_MESSAGES: 6
  # The manual /compact command keeps a smaller window (so it still shrinks a
  # short conversation on demand).
  MANUAL_COMPACT_KEEP_RECENT: 2
  # The kept-verbatim window is ALSO bounded by tokens, walking newest->oldest.
  # This ensures a single oversized recent message (e.g. a pasted document that
  # alone fills the context window) is summarized rather than kept verbatim.
  # Defaults to 25% of MAX_CONVERSATION_TOKENS when unset.
  KEEP_RECENT_TOKEN_BUDGET: 16384
  # Max model<->tools steps per query before the agent loop is cut short and a
  # partial result is returned (LangGraph recursion_limit).
  RECURSION_LIMIT: 50
  # Upper bound (seconds) for a single MCP tool call at the transport layer.
  # Must exceed the longest tool-level timeout (execute_bash allows up to 120s).
  MCP_CALL_TIMEOUT: 300
# Web search Configuration
ENABLE_WEB_SEARCH: true
BRAVE_API_KEY: your_brave_api_key
# Web crawl Configuration
ENABLE_WEB_CRAWL: true
# File system paths
PROFILE:
  NAME: bpistone
  USE_PROFILING: true
# Environment variables exported at startup. Mantle mints its bearer token from
# the standard AWS credential chain; set AWS_PROFILE here to use a named profile,
# or set BEDROCK_API_KEY to authenticate with a short-term Bedrock API key
# instead (no AWS credentials needed).
# ENV:
#   AWS_PROFILE: my-bedrock-profile
#   AWS_REGION: us-east-1
#   BEDROCK_API_KEY: bedrock-api-key-XXXXXXXX
SYSTEM_PROMPT: |
  <identity>
    TODAY'S DATE: {current_date}
    CURRENT YEAR: Extract the year from the date above. Use THIS year in web searches.

    You are a Mnemo AI, a technical AI assistant specialized in software development, document analysis, and system administration. You have access to file operations, search tools, git integration, web search, RAG (document retrieval), and task management tools.

    Core principles:
    - Execute actions immediately when requested
    - Be direct and solution-focused
    - Use tools proactively to verify information before responding
    - When facing similar tasks, you may receive relevant context from past successful completions
  </identity>
  <communication>
    Style: Professional, direct, technically precise.
    Examples: Provide complete, working code with explanatory comments.
    Security: Use placeholders (<api_key>, <email>) for sensitive data. Assist with authorized security work — defensive security, penetration testing, CTF challenges, security research, and dual-use tooling given clear context. Decline requests aimed at destruction, mass targeting, or other clearly malicious use.
  </communication>
  <information_sources>
    Choose the right source based on the question type:

    1. USER DOCUMENTS (RAG) - Use first when:
      - Possessive language: "our docs", "my project", "the guide we use"
      - Domain-specific terms that might be in uploaded docs
      - Ambiguous technical questions (user may have specific guidance)
      Workflow: list_documents() -> search_in_documents(3-6 keywords) -> use or fallback

    2. WEB TOOLS - Choose correctly:
      - web_crawler(url="https://...") - For reading specific URLs provided by the user.
      - web_search(query="...") - For general queries, news, prices. Always include CURRENT YEAR in searches for recent information.

    3. INTERNAL KNOWLEDGE - Use for:
      - Fundamental concepts (recursion, neural networks)
      - Stable facts (capitals, constants, history)
      - Established practices (Git workflows, API patterns)
      - Coding assistance and calculations

    For multi-source questions ("compare our approach to industry standard"), combine RAG + web search. Fallback gracefully without announcing failed searches.
  </information_sources>
  <guardrails>
    <reasoning>
      Keep reasoning brief (3-4 sentences), then act. State each thought once and move forward.
      When you need information, call a tool immediately rather than speculating.
      If you find yourself revisiting the same topic, either call a tool for concrete data or give your best answer with what you have.
      When you have enough to act, act. Do not re-derive facts already established earlier in the conversation, re-ask about decisions the user has already made, or narrate options you will not pursue.
      When weighing a choice, give a recommendation, not an exhaustive survey.
    </reasoning>

    <error_handling>
      When tools fail:
      1. Report the specific error clearly
      2. Identify likely causes
      3. Suggest alternatives or fixes

      When uncertain, verify with available tools before responding. Be honest about limitations and suggest alternative approaches.
    </error_handling>
  </guardrails>
  <engineering>
    Match the surrounding code: follow the file's existing naming, idiom, and comment density. Read before you write.
    Report outcomes faithfully: if a command or test fails, show the error; if you skipped a step, say so; never claim success you have not verified.
    For actions that are hard to reverse or outward-facing (deleting files, force-pushing, writing outside the project), confirm first unless the user already told you to proceed.
    Tools run behind a safety layer. If a call is blocked or returns requires_confirmation, adjust and explain rather than retrying the identical call.
  </engineering>
  <examples>
    <example title="Tool-first approach">
      User: "What version of Python does our project use?"
      Good: Call list_documents(), then search_in_documents("python version requirements"), then answer based on results.
      Bad: Guess "probably Python 3.11" without checking.
    </example>

    <example title="Multi-source research">
      User: "How does our auth flow compare to OAuth 2.0 best practices?"
      Good: search_in_documents("auth flow authentication") for the project's approach, then web_search("OAuth 2.0 best practices CURRENT YEAR") for industry standard, then compare both.
    </example>

    <example title="Direct action">
      User: "Add error handling to the login function in auth.py"
      Good: fs_read("auth.py") -> identify the login function -> file_edit with the improvement -> show result.
      Bad: "Would you like me to add error handling?" (user already requested it).
    </example>
  </examples>
  <output_format>
    Use markdown for code blocks with language identifiers (```python, ```bash, etc.).
    Use backticks for inline code and file paths.
    Return code in markdown blocks unless the user specifies a file path to save to.
    Respond directly with the final answer. Skip preambles like "Here is..." or "Sure, I can...".
  </output_format>

# Credentials: Bedrock/SageMaker use the standard boto3 credential chain
# (default profile / env vars / instance role). To use a named AWS profile,
# set AWS_PROFILE in the ENV section at the bottom of this file.
MODEL_ID:
  NAME: global.anthropic.claude-opus-4-8
  TYPE: bedrock
  MAX_TOKENS: 128000
  # Omit TEMPERATURE for newer Claude models that reject it as deprecated.
  # REASONING: true            # enable extended thinking
  # REASONING_EFFORT: medium   # low | medium | high | max
VISION_MODEL_ID:
  NAME: global.anthropic.claude-opus-4-8
  TYPE: bedrock
# Model parameters
MAX_CONVERSATION_TOKENS: 1000000
DOC_MAX_TOKENS: 524288
# Ask for confirmation before every execute_bash shell command (Claude Code-style).
# Set to false to run shell commands without prompting (trusted/automation setups).
REQUIRE_BASH_CONFIRMATION: true
# Ask for confirmation before every fs_write / file_edit file modification.
# Set to false to write files without prompting (trusted/automation setups).
REQUIRE_WRITE_CONFIRMATION: true
# Ask for confirmation before each persistent-memory write (default off:
# the agent curates MEMORY.md automatically, Hermes-style). Set true to gate.
REQUIRE_MEMORY_CONFIRMATION: false
# RAG Configuration
ENABLE_RAG: true
RAG:
  MAX_TOKENS: 8192
  EMBED_MODEL_ID:
    NAME: qwen3-embedding:0.6b
    TYPE: ollama
    HOST: localhost
    PORT: 11434
  CHUNK_TOKENS: 1024
  SEARCH:
    SEMANTIC_WEIGHT: 0.5 # Semantic similarity weight (0-1)
    KEYWORD_WEIGHT: 0.5 # BM25 keyword weight (0-1)
  VECTOR_STORE:
    TYPE: chromadb # or faiss
  EMBEDDINGS:
    FALLBACK_ENABLED: true
    FALLBACK_TYPE: "sha256" # or "random", "zeros"
    CACHE_ENABLED: true
    CACHE_SIZE: 1000 # LRU cache size for embeddings
# Episodic Memory Configuration (Enhanced)
ENABLE_EPISODIC_MEMORY: true
EPISODIC_MEMORY:
  ENABLED: true
  STORE_TYPE: chromadb # or faiss
  # Similarity Thresholds
  DUPLICATE_THRESHOLD: 0.95 # Higher = stricter duplicate detection
  RETRIEVAL_THRESHOLD: 0.7 # Higher = more strict retrieval
  # Hybrid Search Weights
  SEMANTIC_WEIGHT: 0.7 # Semantic similarity weight (0-1)
  KEYWORD_WEIGHT: 0.3 # Keyword matching weight (0-1)
  # Token and Size Limits
  MAX_TOKENS_PER_EPISODE: 400 # Max tokens for episode text
  MAX_EPISODES: 1000 # Maximum stored episodes
  MAX_AGE_DAYS: 90 # Maximum episode age
  # Success Detection (configurable markers)
  SUCCESS_MARKERS:
    - thanks
    - thank you
    - perfect
    - great
    - worked
    - good
    - excellent
    - awesome
  CORRECTION_MARKERS:
    - wrong
    - error
    - fix
    - actually
    - instead
    - incorrect
    - "no"
    - not right
  ERROR_PATTERNS:
    - "error:"
    - "failed:"
    - "exception:"
    - "could not"
    - "unable to"
    - "error occurred"
    - "failed to"
    - "an error"
    - "the error"
  # Storage Behavior
  IMMEDIATE_STORAGE: true # Store episodes immediately (not delayed)
  MIN_TOOLS_OR_LENGTH: 300 # Minimum response length if no tools used
  # Query Enhancement
  ENABLE_QUERY_EXPANSION: true # Expand queries with synonyms
  QUERY_EXPANSION_TERMS: 3 # Max terms to add per query
# Persistent curated memory (MEMORY.md): a small, bounded markdown file the
# agent maintains itself and that is injected whole into the system prompt at
# session start. Complements episodic memory (which is similarity-retrieved).
ENABLE_MEMORY: true
MEMORY:
  MAX_CHARS: 2200   # hard cap; agent must consolidate when full
# ACE Playbook Configuration (Agentic Context Engineering)
ENABLE_PLAYBOOK: true
PLAYBOOK:
  MAX_ENTRIES: 500 # Maximum playbook entries before refinement
  SIMILARITY_THRESHOLD: 0.85 # Threshold for merging similar strategies
  MAX_INJECT: 10 # Maximum entries to inject per query

# Query Routing Configuration
# When enabled, queries are classified and routed to specialized tool subsets
# Categories: simple_qa (no tools), code, research, knowledge, full (all tools)
ENABLE_ROUTING: true
ENABLE_ORCHESTRATION: true
LLM:
  # Thinking/Reasoning
  ENABLE_THINKING: true # Enable thinking tags (verbose mode)
  # Retry Logic
  RETRY_ENABLED: true
  MAX_RETRIES: 5 # Also caps retries of a transient *empty* model response
  RETRY_DELAY: 1.0 # Seconds between retries
  RETRY_BACKOFF: 2.0 # Exponential backoff multiplier
  # Token Counting (Model-specific)
  TOKEN_COUNTING:
    OLLAMA_APPROXIMATION: 1.3 # Multiplier for Ollama (chars to tokens)
    FALLBACK_MODEL: "gpt-4" # Tiktoken model for fallback
  # Context Management
  SUMMARIZATION_THINK: false
  # Compaction: when the conversation exceeds MAX_CONVERSATION_TOKENS it is
  # auto-compacted — older messages are summarized into the system prompt while
  # the most recent messages are kept verbatim.
  KEEP_RECENT_MESSAGES: 6
  # The manual /compact command keeps a smaller window (so it still shrinks a
  # short conversation on demand).
  MANUAL_COMPACT_KEEP_RECENT: 2
  # The kept-verbatim window is ALSO bounded by tokens, walking newest->oldest.
  # This ensures a single oversized recent message (e.g. a pasted document that
  # alone fills the context window) is summarized rather than kept verbatim.
  # Defaults to 25% of MAX_CONVERSATION_TOKENS when unset.
  KEEP_RECENT_TOKEN_BUDGET: 16384
  # Max model<->tools steps per query before the agent loop is cut short and a
  # partial result is returned (LangGraph recursion_limit). Set high so
  # legitimate long tasks aren't capped — context compaction is the real
  # limiter, as in Claude Code; this is just a runaway guard.
  RECURSION_LIMIT: 200
  # Upper bound (seconds) for a single MCP tool call at the transport layer.
  # Must exceed the longest tool-level timeout (execute_bash allows up to 120s).
  MCP_CALL_TIMEOUT: 300
# Web search Configuration
ENABLE_WEB_SEARCH: true
BRAVE_API_KEY: your_brave_api_key
# Web crawl Configuration
ENABLE_WEB_CRAWL: true
# File system paths
PROFILE:
  NAME: bpistone
  USE_PROFILING: true
# Environment variables exported at startup. Use this to select a named AWS
# profile for Bedrock/SageMaker without changing your shell, to pass a Bedrock
# API key, or to set any other env var the providers read.
# ENV:
#   AWS_PROFILE: my-bedrock-profile
#   AWS_REGION: us-east-1
#   # Short-term Bedrock API key (alternative to AWS credentials):
#   AWS_BEARER_TOKEN_BEDROCK: bedrock-api-key-XXXXXXXX
